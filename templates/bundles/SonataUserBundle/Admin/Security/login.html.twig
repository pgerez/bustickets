{% extends base_template %}

{% block sonata_nav %}
{% endblock sonata_nav %}

{% block logo %}
{% endblock logo %}

{% block sonata_left_side %}
{% endblock sonata_left_side %}

{% block body_attributes %}class="sonata-bc login-page"{% endblock %}

{% block sonata_wrapper %}
<style>
    body.login-page {
        background: linear-gradient(135deg, #10b981 0%, #047857 100%) !important;
        font-family: 'Inter', 'Segoe UI', Roboto, sans-serif !important;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .login-box {
        width: 100%;
        max-width: 420px;
        margin: 0 auto;
        padding: 10px;
    }
    .login-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        padding: 40px 30px;
        border: 1px solid rgba(255, 255, 255, 0.8);
    }
    .login-logo-container {
        text-align: center;
        margin-bottom: 25px;
    }
    .login-logo-container img {
        height: 70px;
        width: 70px;
        object-fit: contain;
    }
    .login-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        text-align: center;
        margin-bottom: 6px;
        letter-spacing: -0.5px;
    }
    .login-subtitle {
        font-size: 0.875rem;
        color: #6b7280;
        text-align: center;
        margin-bottom: 25px;
    }
    .form-group {
        margin-bottom: 20px;
        position: relative;
    }
    .form-group label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #4b5563;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
        display: block;
    }
    .form-control-custom {
        width: 100%;
        border-radius: 8px !important;
        border: 1px solid #d1d5db !important;
        padding: 12px 14px !important;
        font-size: 0.95rem !important;
        height: auto !important;
        box-shadow: none !important;
        transition: border-color 0.15s, box-shadow 0.15s !important;
    }
    .form-control-custom:focus {
        border-color: #10b981 !important;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15) !important;
        outline: 0;
    }
    .btn-login-custom {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
        color: #ffffff !important;
        border: none !important;
        border-radius: 8px !important;
        padding: 12px 20px !important;
        font-weight: 600 !important;
        width: 100% !important;
        font-size: 1rem !important;
        box-shadow: 0 4px 6px rgba(16, 185, 129, 0.15) !important;
        transition: transform 0.1s, box-shadow 0.15s !important;
    }
    .btn-login-custom:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 12px rgba(16, 185, 129, 0.25) !important;
    }
    .btn-login-custom:active {
        transform: translateY(0);
    }
    .alert-custom {
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 0.875rem;
        margin-bottom: 20px;
        border: 1px solid #fca5a5;
        background-color: #fef2f2;
        color: #b91c1c;
    }
    .checkbox-custom {
        margin-top: 10px;
        font-size: 0.9rem;
        color: #4b5563;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .checkbox-custom input {
        margin: 0;
    }
</style>

<div class="login-box">
    <div class="login-card">
        <div class="login-logo-container">
            <img src="{{ asset('images/bus.png') }}" alt="Santiagueño Bus Logo" />
        </div>
        <h2 class="login-title">Administración</h2>
        <p class="login-subtitle">Ingresá tus credenciales de acceso</p>

        {% block sonata_user_login_form %}
            {% block sonata_user_login_error %}
                {% if error %}
                    <div class="alert alert-custom">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}
            {% endblock %}

            <form action="{{ path("sonata_user_admin_security_check") }}" method="post" role="form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}"/>

                <div class="form-group">
                    <label for="username">Usuario / Email</label>
                    <input class="form-control-custom"
                        id="username"
                        name="_username"
                        placeholder="Ingresá tu usuario"
                        required="required"
                        type="text"
                        value="{{ last_username }}"
                        autofocus/>
                </div>

                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input class="form-control-custom"
                        id="password"
                        name="_password"
                        placeholder="Ingresá tu contraseña"
                        required="required"
                        type="password"/>
                </div>

                <div class="form-group">
                    <label class="checkbox-custom">
                        <input type="checkbox" id="remember_me" name="_remember_me" value="on"/>
                        Recordarme en este equipo
                    </label>
                </div>

                <button type="submit" name="submit" class="btn-login-custom">
                    Ingresar al Panel
                </button>
            </form>

            {% if reset_route|default %}
                <div style="text-align: center; margin-top: 20px;">
                    <a href="{{ reset_route }}" style="color: #059669; font-size: 0.875rem; font-weight: 500;">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>
            {% endif %}
        {% endblock %}
    </div>
</div>
{% endblock sonata_wrapper %}
