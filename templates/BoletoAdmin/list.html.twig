{% extends '@SonataAdmin/CRUD/base_list.html.twig' %}

{% block list_table %}
    <style>
        /* Mobile First Styling for Drivers */
        .driver-mobile-container {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 5px;
        }

        /* Sticky Control Dashboard at top of mobile screen */
        .driver-sticky-header {
            position: -webkit-sticky;
            position: sticky;
            top: 50px;
            z-index: 1000;
            background: #ffffff;
            border-radius: 14px;
            padding: 14px 16px;
            margin-bottom: 15px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            border: 1px solid #e2e8f0;
        }

        .driver-stats-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            gap: 8px;
        }

        .stat-badge-item {
            flex: 1;
            padding: 8px 6px;
            border-radius: 8px;
            text-align: center;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }
        .stat-badge-item.stat-total {
            background-color: #f1f5f9;
            border-color: #cbd5e1;
            color: #334155;
        }
        .stat-badge-item.stat-abordo {
            background-color: #ecfdf5;
            border-color: #a7f3d0;
            color: #047857;
        }
        .stat-badge-item.stat-pendientes {
            background-color: #fffbeb;
            border-color: #fde68a;
            color: #b45309;
        }

        .stat-val {
            font-size: 20px;
            font-weight: 800;
            line-height: 1;
        }
        .stat-lbl {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 3px;
        }

        /* Large touch-friendly search input */
        .mobile-search-wrapper {
            position: relative;
            margin-bottom: 10px;
        }
        .mobile-search-input {
            width: 100% !important;
            height: 48px !important;
            font-size: 16px !important;
            padding: 10px 40px 10px 42px !important;
            border-radius: 24px !important;
            border: 2px solid #2563eb !important;
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.12) !important;
            outline: none !important;
            box-sizing: border-box !important;
        }
        .mobile-search-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #2563eb;
            font-size: 18px;
        }
        .mobile-clear-btn {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 18px;
            cursor: pointer;
            display: none;
            padding: 4px;
        }

        /* Filter Tabs */
        .mobile-filter-pills {
            display: flex;
            gap: 6px;
            overflow-x: auto;
            padding-bottom: 2px;
            -webkit-overflow-scrolling: touch;
        }
        .filter-pill {
            flex: 1;
            white-space: nowrap;
            padding: 7px 12px;
            border-radius: 20px;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            font-size: 12px;
            font-weight: 700;
            color: #475569;
            text-align: center;
            cursor: pointer;
            transition: all 0.15s ease;
        }
        .filter-pill.active {
            background: #2563eb;
            color: #ffffff;
            border-color: #2563eb;
            box-shadow: 0 2px 6px rgba(37, 99, 235, 0.25);
        }

        /* Passenger Card Items */
        .driver-cards-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .driver-passenger-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);
            transition: all 0.2s ease;
        }
        .driver-passenger-card.is-abordo {
            border-left: 6px solid #10b981;
            background-color: #f0fdf4;
        }
        .driver-passenger-card.is-pendiente {
            border-left: 6px solid #f59e0b;
        }

        /* Big Seat Badge */
        .seat-badge-box {
            background: #0f172a;
            color: #ffffff;
            border-radius: 10px;
            padding: 8px 10px;
            text-align: center;
            min-width: 65px;
            flex-shrink: 0;
        }
        .seat-lbl {
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            color: #94a3b8;
            letter-spacing: 0.5px;
        }
        .seat-num {
            font-size: 22px;
            font-weight: 900;
            line-height: 1;
        }

        /* Info Text */
        .pass-info-container {
            flex-grow: 1;
            min-width: 0;
        }
        .pass-name {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 2px;
        }
        .pass-dni {
            font-size: 13px;
            font-weight: 600;
            color: #475569;
        }

        /* Big Touch Action Button */
        .touch-action-btn {
            height: 44px;
            padding: 0 16px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 800;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            flex-shrink: 0;
            min-width: 110px;
            transition: all 0.15s ease;
            touch-action: manipulation;
        }
        .touch-action-btn.btn-embarcar {
            background-color: #10b981;
            color: #ffffff;
            box-shadow: 0 3px 10px rgba(16, 185, 129, 0.3);
        }
        .touch-action-btn.btn-embarcar:active {
            transform: scale(0.96);
            background-color: #059669;
        }
        .touch-action-btn.btn-abordo {
            background-color: #ecfdf5;
            color: #047857;
            border: 1.5px solid #a7f3d0;
        }

        /* Empty State */
        .driver-empty-state {
            text-align: center;
            padding: 35px 20px;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            color: #64748b;
        }
    </style>

    <div class="driver-mobile-container">
        {% set total_boletos = datagrid.results|length %}
        {% set embarcados_count = 0 %}
        {% set pendientes_count = 0 %}

        {% for boleto in datagrid.results %}
            {% if boleto.estado == 2 %}
                {% set embarcados_count = embarcados_count + 1 %}
            {% else %}
                {% set pendientes_count = pendientes_count + 1 %}
            {% endif %}
        {% endfor %}

        <!-- Sticky Header for Mobile Phone -->
        <div class="driver-sticky-header">
            <div class="driver-stats-bar">
                <div class="stat-badge-item stat-total">
                    <div class="stat-val" id="stat-total">{{ total_boletos }}</div>
                    <div class="stat-lbl">Total</div>
                </div>
                <div class="stat-badge-item stat-abordo">
                    <div class="stat-val" id="stat-embarcados">{{ embarcados_count }}</div>
                    <div class="stat-lbl">Abordo</div>
                </div>
                <div class="stat-badge-item stat-pendientes">
                    <div class="stat-val" id="stat-pendientes">{{ pendientes_count }}</div>
                    <div class="stat-lbl">Pendientes</div>
                </div>
            </div>

            <!-- Instant Search Box -->
            <div class="mobile-search-wrapper">
                <i class="fa fa-search mobile-search-icon"></i>
                <input type="text" id="driver-search-input" class="mobile-search-input" placeholder="Buscar por DNI, Nombre o Asiento..." autocomplete="off" autocorrect="off" capitalize="off">
                <i class="fa fa-times-circle mobile-clear-btn" id="mobile-clear-btn"></i>
            </div>

            <!-- Status Filter Pills -->
            <div class="mobile-filter-pills">
                <div class="filter-pill active" data-filter="all">Todos ({{ total_boletos }})</div>
                <div class="filter-pill" data-filter="pendiente">⏳ Pendientes ({{ pendientes_count }})</div>
                <div class="filter-pill" data-filter="embarcado">✅ Abordo ({{ embarcados_count }})</div>
            </div>
        </div>

        <!-- Passenger Cards -->
        <div class="driver-cards-list" id="driver-cards-list">
            {% for object in datagrid.results %}
                {% set is_taken = (object.estado == 2) %}
                {% set item_status = is_taken ? 'embarcado' : 'pendiente' %}
                {% set pasajero_nombre = object.pasajero ? (object.pasajero.nombre ~ ' ' ~ object.pasajero.apellido)|trim : 'Sin Pasajero' %}
                {% set pasajero_dni = object.pasajero ? object.pasajero.dni : '' %}
                {% set asiento_num = object.asiento ? object.asiento.numero : '-' %}

                <div class="driver-passenger-card {{ is_taken ? 'is-abordo' : 'is-pendiente' }}"
                     data-status="{{ item_status }}"
                     data-search="{{ (asiento_num ~ ' ' ~ pasajero_nombre ~ ' ' ~ pasajero_dni)|lower }}">
                    
                    <div class="seat-badge-box">
                        <div class="seat-lbl">Asiento</div>
                        <div class="seat-num">{{ asiento_num }}</div>
                    </div>

                    <div class="pass-info-container">
                        <div class="pass-name">{{ pasajero_nombre }}</div>
                        <div class="pass-dni">
                            {% if pasajero_dni %}
                                <i class="fa fa-id-card" style="margin-right: 4px; color: #94a3b8;"></i>DNI: <strong>{{ pasajero_dni }}</strong>
                            {% else %}
                                <span style="color: #94a3b8; font-style: italic;">Sin DNI</span>
                            {% endif %}
                        </div>
                    </div>

                    <div>
                        <button type="button" 
                                class="touch-action-btn {{ is_taken ? 'btn-abordo' : 'btn-embarcar' }}"
                                data-action-url="{{ path('admin_app_boleto_asignarliberarasiento', {'id': object.id, 'ajax': 1}) }}"
                                data-asiento="{{ asiento_num }}"
                                data-pasajero="{{ pasajero_nombre }}"
                                data-is-taken="{{ is_taken ? '1' : '0' }}">
                            {% if is_taken %}
                                <i class="fa fa-check-circle"></i> <span class="btn-lbl">ABORDO</span>
                            {% else %}
                                <i class="fa fa-user-check"></i> <span class="btn-lbl">EMBARCAR</span>
                            {% endif %}
                        </button>
                    </div>
                </div>
            {% else %}
                <div class="driver-empty-state">
                    <i class="fa fa-users fa-2x" style="margin-bottom: 8px; color: #94a3b8;"></i>
                    <p style="margin: 0; font-size: 15px; font-weight: 600;">No hay pasajeros o pasajes para este servicio.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
            var searchInput = document.getElementById('driver-search-input');
            var clearBtn = document.getElementById('mobile-clear-btn');
            var filterPills = document.querySelectorAll('.filter-pill');
            var cards = document.querySelectorAll('.driver-passenger-card');
            var activeFilter = 'all';

            function filterList() {
                var query = searchInput.value.toLowerCase().trim();
                
                if (query.length > 0) {
                    clearBtn.style.display = 'block';
                } else {
                    clearBtn.style.display = 'none';
                }

                cards.forEach(function(card) {
                    var status = card.getAttribute('data-status');
                    var searchData = card.getAttribute('data-search');

                    var matchesQuery = (query === '' || searchData.indexOf(query) !== -1);
                    var matchesStatus = (activeFilter === 'all' || status === activeFilter);

                    if (matchesQuery && matchesStatus) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', filterList);
            }

            if (clearBtn) {
                clearBtn.addEventListener('click', function() {
                    searchInput.value = '';
                    filterList();
                    searchInput.focus();
                });
            }

            filterPills.forEach(function(pill) {
                pill.addEventListener('click', function() {
                    filterPills.forEach(function(p) { p.classList.remove('active'); });
                    this.classList.add('active');
                    activeFilter = this.getAttribute('data-filter');
                    filterList();
                });
            });

            // Instant Touch AJAX Action
            document.querySelectorAll('.touch-action-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var button = this;
                    var card = button.closest('.driver-passenger-card');
                    var isTaken = (button.getAttribute('data-is-taken') === '1');
                    var asiento = button.getAttribute('data-asiento');
                    var pasajero = button.getAttribute('data-pasajero');
                    var url = button.getAttribute('data-action-url');

                    var confirmMsg = isTaken 
                        ? '¿Deseas LIBERAR el asiento ' + asiento + ' de ' + pasajero + '?' 
                        : '¿CONFIRMAR EMBARQUE de ' + pasajero + ' (Asiento ' + asiento + ')?';

                    if (!confirm(confirmMsg)) {
                        return;
                    }

                    button.disabled = true;

                    fetch(url, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                        button.disabled = false;
                        if (data.success) {
                            var newTaken = (data.nuevoEstado === 2);
                            button.setAttribute('data-is-taken', newTaken ? '1' : '0');
                            card.setAttribute('data-status', newTaken ? 'embarcado' : 'pendiente');

                            if (newTaken) {
                                card.classList.remove('is-pendiente');
                                card.classList.add('is-abordo');
                                button.classList.remove('btn-embarcar');
                                button.classList.add('btn-abordo');
                                button.innerHTML = '<i class="fa fa-check-circle"></i> <span class="btn-lbl">ABORDO</span>';
                            } else {
                                card.classList.remove('is-abordo');
                                card.classList.add('is-pendiente');
                                button.classList.remove('btn-abordo');
                                button.classList.add('btn-embarcar');
                                button.innerHTML = '<i class="fa fa-user-check"></i> <span class="btn-lbl">EMBARCAR</span>';
                            }

                            recalculateStats();
                            filterList();
                        }
                    })
                    .catch(function(err) {
                        button.disabled = false;
                        window.location.href = url;
                    });
                });
            });

            function recalculateStats() {
                var total = cards.length;
                var abordo = document.querySelectorAll('.driver-passenger-card.is-abordo').length;
                var pendientes = total - abordo;

                document.getElementById('stat-embarcados').textContent = abordo;
                document.getElementById('stat-pendientes').textContent = pendientes;

                var pillAll = document.querySelector('.filter-pill[data-filter="all"]');
                var pillPend = document.querySelector('.filter-pill[data-filter="pendiente"]');
                var pillEmb = document.querySelector('.filter-pill[data-filter="embarcado"]');

                if (pillAll) pillAll.textContent = 'Todos (' + total + ')';
                if (pillPend) pillPend.textContent = '⏳ Pendientes (' + pendientes + ')';
                if (pillEmb) pillEmb.textContent = '✅ Abordo (' + abordo + ')';
            }
        });
    </script>
{% endblock %}
