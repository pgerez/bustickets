{% extends 'sitebase.html.twig' %}

{% block body_center %}
    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Santiagueño Bus - Registro</title>
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('css/custom.css') }}">
        <style>
            body {
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
                background-color: #f9fafb;
                color: #1f2937;
            }
            
            /* Encabezado Corporativo */
            .hero-section {
                background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(4, 120, 87, 0.95) 100%), url({{ asset('images/header.jpg') }});
                background-size: cover;
                background-position: center;
                min-height: 700px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 20px;
                position: relative;
            }

            .hero-container {
                max-width: 1000px;
                width: 100%;
                display: grid;
                grid-template-columns: 1fr;
                gap: 40px;
                align-items: center;
            }

            @media (min-width: 992px) {
                .hero-container {
                    grid-template-columns: 1.2fr 0.8fr;
                }
            }

            .hero-text {
                color: #ffffff;
            }

            .hero-text h1 {
                font-size: 2.8rem;
                font-weight: 800;
                line-height: 1.2;
                margin-bottom: 20px;
                letter-spacing: -1px;
            }

            .hero-text p {
                font-size: 1.2rem;
                opacity: 0.9;
                margin-bottom: 30px;
                line-height: 1.6;
            }

            /* Tarjeta de Registro */
            .login-card {
                background: #ffffff;
                border-radius: 16px;
                box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
                padding: 35px 30px;
                border: 1px solid rgba(255, 255, 255, 0.8);
            }

            .login-logo {
                text-align: center;
                margin-bottom: 15px;
            }

            .login-logo img {
                height: 55px;
                width: 55px;
                object-fit: contain;
            }

            .login-title {
                font-size: 1.3rem;
                font-weight: 700;
                color: #111827;
                text-align: center;
                margin-bottom: 6px;
            }

            .login-subtitle {
                font-size: 0.85rem;
                color: #6b7280;
                text-align: center;
                margin-bottom: 20px;
            }

            .form-group label {
                font-size: 0.8rem;
                font-weight: 700;
                color: #4b5563;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 4px;
            }

            .form-control-custom {
                border-radius: 8px;
                border: 1px solid #d1d5db;
                padding: 10px 14px;
                height: auto;
                font-size: 0.9rem;
                width: 100%;
                box-sizing: border-box;
                transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
            }

            .form-control-custom:focus {
                border-color: #10b981;
                box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
                outline: 0;
            }

            .btn-login {
                background: linear-gradient(135deg, #10b981 0%, #059669 100%);
                color: #ffffff;
                border: none;
                border-radius: 8px;
                padding: 12px 20px;
                font-weight: 600;
                width: 100%;
                margin-top: 10px;
                transition: transform 0.1s, box-shadow 0.15s;
                box-shadow: 0 4px 6px rgba(16, 185, 129, 0.15);
            }

            .btn-login:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 12px rgba(16, 185, 129, 0.25);
                color: #ffffff;
            }

            .btn-login:active {
                transform: translateY(0);
            }

            /* Introducción y Servicios */
            .intro-section {
                padding: 60px 20px;
                background-color: #ffffff;
                border-bottom: 1px solid #f3f4f6;
            }

            .section-header {
                text-align: center;
                margin-bottom: 40px;
            }

            .section-header h2 {
                font-size: 2rem;
                font-weight: 800;
                color: #111827;
            }

            .feature-card {
                text-align: center;
                padding: 30px 20px;
                border-radius: 12px;
                transition: transform 0.2s;
            }

            .feature-card:hover {
                transform: translateY(-4px);
            }

            .feature-icon-wrapper {
                background-color: #ecfdf5;
                color: #10b981;
                width: 60px;
                height: 60px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
            }

            .feature-card h3 {
                font-size: 1.25rem;
                font-weight: 700;
                color: #111827;
                margin-bottom: 10px;
            }

            .feature-card p {
                color: #4b5563;
                font-size: 0.95rem;
            }

            /* Galería */
            .gallery-section {
                padding: 60px 20px;
                background-color: #f9fafb;
            }

            .gallery-img-wrapper {
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 4px 6px rgba(0,0,0,0.02);
                margin-bottom: 30px;
                transition: transform 0.2s;
            }

            .gallery-img-wrapper:hover {
                transform: scale(1.02);
            }

            .gallery-img-wrapper img {
                width: 100%;
                height: 250px;
                object-fit: cover;
            }

            /* Footer */
            footer {
                background-color: #064e3b;
                color: #a7f3d0;
                padding: 40px 20px;
                text-align: center;
                font-size: 0.9rem;
                border-top: 1px solid #047857;
            }
        </style>
    </head>
    <body>

    <!-- Hero Section with Register Form -->
    <div class="hero-section">
        <div class="hero-container">
            <div class="hero-text">
                <h1>Viajá de Forma Inteligente y Segura</h1>
                <p>Gestioná tus pasajes corporativos y personales de forma ágil desde nuestro nuevo portal de autogestión. Confort y puntualidad garantizados para tus viajes en Santiago del Estero.</p>
            </div>
            
            <div class="login-card">
                <div class="login-logo">
                    <img src="{{ asset('images/bus.png') }}" alt="Santiagueño Bus Logo" />
                </div>
                <h2 class="login-title">Crear Cuenta</h2>
                <p class="login-subtitle">Completá tus datos para registrarte en el portal</p>
                
                <form action="{{ path('register') }}" method="POST">
                    <div class="form-group">
                        {{ form_label(form.email, 'Dirección de Email') }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control-custom', 'placeholder': 'nombre@ejemplo.com'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.nombre, 'Nombre') }}
                        {{ form_widget(form.nombre, {'attr': {'class': 'form-control-custom', 'placeholder': 'Tu nombre'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.apellido, 'Apellido') }}
                        {{ form_widget(form.apellido, {'attr': {'class': 'form-control-custom', 'placeholder': 'Tu apellido'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.nro_documento, 'DNI / Documento') }}
                        {{ form_widget(form.nro_documento, {'attr': {'class': 'form-control-custom', 'placeholder': 'Número de documento'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.sexo, 'Sexo') }}
                        {{ form_widget(form.sexo, {'attr': {'class': 'form-control-custom'}}) }}
                    </div>
                    
                    <button type="submit" class="btn btn-login">
                        Registrarse y Acceder
                    </button>
                    
                    {{ form_errors(form) }}
                    {{ form_rest(form) }}
                </form>
            </div>
        </div>
    </div>

    <!-- Spinner Overlay -->
    <div class="spinner-overlay" style="display: none;">
        <div class="spinner-container">
            <div class="bus-loader-container">
                <div class="bus-icon">
                    <img src="{{ asset('images/bus.png') }}" style="width: 50px; height: 50px; object-fit: contain;" alt="Santiagueño Bus" />
                </div>
                <div class="road-line"></div>
            </div>
            <p style="font-weight: 600; color: #374151; margin: 0;">Guardando registro y enviando acceso...</p>
        </div>
    </div>

    <!-- Sección de presentación -->
    <div class="intro-section">
        <div class="container">
            <div class="section-header">
                <h2>Servicio Corporativo Premium</h2>
                <p class="text-muted">Un estándar de viaje diseñado para la máxima comodidad de tu equipo</p>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                        </div>
                        <h3>Viajes Seguros</h3>
                        <p>Flotas modernas equipadas con la última tecnología en seguridad y rastreo satelital constante.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3>Puntualidad Absoluta</h3>
                        <p>Monitoreo dinámico de rutas y horarios rigurosos para que llegues a destino exactamente a tiempo.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <h3>Máximo Confort</h3>
                        <p>Unidades semicama y cama con climatización, puertos USB y butacas ergonómicas premium.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Galería de fotos -->
    <div class="gallery-section">
        <div class="container">
            <div class="section-header">
                <h2>Nuestra Flota</h2>
                <p class="text-muted">Unidades de última generación listas para tu viaje</p>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEh2NBXuWS9ArxZFDCQgBNiRzRH421Yg_tVJyjA-RwWstxtrVks5WabU9663B7RPd68GPPbu5Micj5QpP6Sb-0HAciviZ9W9jNe9QgLVZCCPTy4-5S1SlTktAr453FZeG9vBVD2gO5vW6W5jEIBM_nDNbIzW-95FRX0dTxzGYmec1ecvfTVBLMqqP_EYyQ/w1200-h630-p-k-no-nu/225.png" alt="Unidad Santiagueño Bus 1">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://live.staticflickr.com/4867/44211518600_c7b00d957b.jpg" alt="Unidad Santiagueño Bus 2">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://bus-america.com/galeria/albums/userpics/10002/84/normal_ScaK400B6x2eV-ComilCampioneDD_17a60-SantiaguenoBus650mattieloV36aa575KRb_1546-120522.JPG" alt="Unidad Santiagueño Bus 3">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pie de página -->
    <footer>
        <p style="font-weight: 700; color: #ffffff; margin-bottom: 10px;">Santiagueño Bus</p>
        <p>&copy; {{ "now"|date("Y") }} Santiagueño Bus - Todos los derechos reservados.</p>
    </footer>

    <!-- Scripts Bootstrap y dependencias -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .spinner-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(17, 24, 39, 0.6);
            z-index: 9999;
        }

        .spinner-container {
            text-align: center;
            background: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15);
        }

        .bus-loader-container {
            position: relative;
            margin: 0 auto 15px;
            width: 80px;
            text-align: center;
        }

        .bus-icon {
            display: inline-block;
            animation: drive-wiggle 0.3s ease-in-out infinite;
        }

        .road-line {
            width: 100%;
            height: 3px;
            background: repeating-linear-gradient(90deg, #10b981 0px, #10b981 8px, transparent 8px, transparent 16px);
            animation: move-road 0.5s linear infinite;
            margin-top: 4px;
        }

        @keyframes drive-wiggle {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-3px); }
        }

        @keyframes move-road {
            0% { background-position: 16px 0; }
            100% { background-position: 0 0; }
        }
    </style>

    <script>
        document.querySelector('form').addEventListener('submit', function() {
            document.querySelector('.spinner-overlay').style.display = 'flex';
        });
    </script>
    </body>
    </html>
{% endblock %}
