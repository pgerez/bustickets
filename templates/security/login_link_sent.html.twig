{% extends 'sitebase.html.twig' %}

{% block body_center %}
    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Santiagueño Bus - Acceso Enviado</title>
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('css/custom.css') }}">
        <style>
            body {
                font-family: 'Inter', sans-serif;
                margin: 0;
                padding: 0;
                background-color: #f9fafb;
                color: #1f2937;
            }
            
            /* Encabezado Corporativo */
            .hero-section {
                background: linear-gradient(135deg, rgba(16, 185, 129, 0.85) 0%, rgba(4, 120, 87, 0.95) 100%), url({{ asset('images/header.jpg') }});
                background-size: cover;
                background-position: center;
                min-height: 580px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 20px;
                position: relative;
            }

            .hero-container {
                max-width: 1000px;
                width: 100%;
                display: grid;
                grid-template-columns: 1fr;
                gap: 40px;
                align-items: center;
            }

            @media (min-width: 992px) {
                .hero-container {
                    grid-template-columns: 1.2fr 0.8fr;
                }
            }

            .hero-text {
                color: #ffffff;
            }

            .hero-text h1 {
                font-size: 2.8rem;
                font-weight: 800;
                line-height: 1.2;
                margin-bottom: 20px;
                letter-spacing: -1px;
            }

            .hero-text p {
                font-size: 1.2rem;
                opacity: 0.9;
                margin-bottom: 30px;
                line-height: 1.6;
            }

            /* Tarjeta de Éxito */
            .login-card {
                background: #ffffff;
                border-radius: 16px;
                box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
                padding: 40px 30px;
                border: 1px solid rgba(255, 255, 255, 0.8);
                text-align: center;
            }

            .success-icon-wrapper {
                background-color: #ecfdf5;
                color: #10b981;
                width: 70px;
                height: 70px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 25px;
                border: 2px solid #a7f3d0;
            }

            .login-title {
                font-size: 1.4rem;
                font-weight: 700;
                color: #111827;
                margin-bottom: 12px;
            }

            .login-subtitle {
                font-size: 0.95rem;
                color: #4b5563;
                line-height: 1.6;
                margin-bottom: 25px;
            }

            .btn-login {
                background: linear-gradient(135deg, #10b981 0%, #059669 100%);
                color: #ffffff;
                border: none;
                border-radius: 8px;
                padding: 12px 20px;
                font-weight: 600;
                width: 100%;
                text-decoration: none !important;
                display: inline-block;
                transition: transform 0.1s, box-shadow 0.15s;
                box-shadow: 0 4px 6px rgba(16, 185, 129, 0.15);
            }

            .btn-login:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 12px rgba(16, 185, 129, 0.25);
                color: #ffffff;
            }

            /* Introducción y Servicios */
            .intro-section {
                padding: 60px 20px;
                background-color: #ffffff;
                border-bottom: 1px solid #f3f4f6;
            }

            .section-header {
                text-align: center;
                margin-bottom: 40px;
            }

            .section-header h2 {
                font-size: 2rem;
                font-weight: 800;
                color: #111827;
            }

            .feature-card {
                text-align: center;
                padding: 30px 20px;
                border-radius: 12px;
                transition: transform 0.2s;
            }

            .feature-card:hover {
                transform: translateY(-4px);
            }

            .feature-icon-wrapper {
                background-color: #ecfdf5;
                color: #10b981;
                width: 60px;
                height: 60px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
            }

            .feature-card h3 {
                font-size: 1.25rem;
                font-weight: 700;
                color: #111827;
                margin-bottom: 10px;
            }

            .feature-card p {
                color: #4b5563;
                font-size: 0.95rem;
            }

            /* Galería */
            .gallery-section {
                padding: 60px 20px;
                background-color: #f9fafb;
            }

            .gallery-img-wrapper {
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 4px 6px rgba(0,0,0,0.02);
                margin-bottom: 30px;
                transition: transform 0.2s;
            }

            .gallery-img-wrapper:hover {
                transform: scale(1.02);
            }

            .gallery-img-wrapper img {
                width: 100%;
                height: 250px;
                object-fit: cover;
            }

            /* Footer */
            footer {
                background-color: #111827;
                color: #9ca3af;
                padding: 40px 20px;
                text-align: center;
                font-size: 0.9rem;
                border-top: 1px solid #1f2937;
            }
        </style>
    </head>
    <body>

    <!-- Hero Section with Success Message -->
    <div class="hero-section">
        <div class="hero-container">
            <div class="hero-text">
                <h1>Viajá de Forma Inteligente y Segura</h1>
                <p>Gestioná tus pasajes corporativos y personales de forma ágil desde nuestro nuevo portal de autogestión. Confort y puntualidad garantizados para tus viajes en Santiago del Estero.</p>
            </div>
            
            <div class="login-card">
                <div class="success-icon-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 19v-8.93a2 2 0 01.89-1.664l8-5.333a2 2 0 012.22 0l8 5.333A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5m0 0l-1.14.76a2 2 0 01-2.22 0l-1.14-.76" />
                    </svg>
                </div>
                <h2 class="login-title">¡Enlace Enviado!</h2>
                <p class="login-subtitle">
                    Hemos enviado un enlace de acceso seguro a tu dirección de correo electrónico. Revisá tu bandeja de entrada (y la carpeta de spam si es necesario) y hacé click en el enlace para iniciar sesión.
                </p>
                <a href="{{ path('login') }}" class="btn btn-login">
                    Volver al Inicio
                </a>
            </div>
        </div>
    </div>

    <!-- Sección de presentación -->
    <div class="intro-section">
        <div class="container">
            <div class="section-header">
                <h2>Servicio Corporativo Premium</h2>
                <p class="text-muted">Un estándar de viaje diseñado para la máxima comodidad de tu equipo</p>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                        </div>
                        <h3>Viajes Seguros</h3>
                        <p>Flotas modernas equipadas con la última tecnología en seguridad y rastreo satelital constante.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h3>Puntualidad Absoluta</h3>
                        <p>Monitoreo dinámico de rutas y horarios rigurosos para que llegues a destino exactamente a tiempo.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                            </svg>
                        </div>
                        <h3>Máximo Confort</h3>
                        <p>Unidades semicama y cama con climatización, puertos USB y butacas ergonómicas premium.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Galería de fotos -->
    <div class="gallery-section">
        <div class="container">
            <div class="section-header">
                <h2>Nuestra Flota</h2>
                <p class="text-muted">Unidades de última generación listas para tu viaje</p>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEh2NBXuWS9ArxZFDCQgBNiRzRH421Yg_tVJyjA-RwWstxtrVks5WabU9663B7RPd68GPPbu5Micj5QpP6Sb-0HAciviZ9W9jNe9QgLVZCCPTy4-5S1SlTktAr453FZeG9vBVD2gO5vW6W5jEIBM_nDNbIzW-95FRX0dTxzGYmec1ecvfTVBLMqqP_EYyQ/w1200-h630-p-k-no-nu/225.png" alt="Unidad Santiagueño Bus 1">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://live.staticflickr.com/4867/44211518600_c7b00d957b.jpg" alt="Unidad Santiagueño Bus 2">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="gallery-img-wrapper">
                        <img src="https://bus-america.com/galeria/albums/userpics/10002/84/normal_ScaK400B6x2eV-ComilCampioneDD_17a60-SantiaguenoBus650mattieloV36aa575KRb_1546-120522.JPG" alt="Unidad Santiagueño Bus 3">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pie de página -->
    <footer>
        <p style="font-weight: 700; color: #ffffff; margin-bottom: 10px;">Santiagueño Bus</p>
        <p>&copy; {{ "now"|date("Y") }} Santiagueño Bus - Todos los derechos reservados.</p>
    </footer>

    <!-- Scripts Bootstrap y dependencias -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
    </html>
{% endblock %}
